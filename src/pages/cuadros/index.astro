---
import CuadroCard from '../../components/CuadroCard.astro';
import Layout from '../../layouts/Layout.astro';
import { getCuadrosData } from '../../lib/cuadros';

const TITLE = 'Cuadros Bordados Crewel - Las Artesanías de Juanita';
const DESCRIPTION =
	'Galería de cuadros bordados en lana con técnica crewel. Piezas únicas de bordado crewel hechas a mano por Juanita en Chile.';

const cuadros = await getCuadrosData();
---

<Layout title={TITLE} description={DESCRIPTION}>
	<section class="mx-auto max-w-6xl px-4 py-16 md:px-6 md:py-20">
		<header class="mb-12 max-w-2xl">
			<h1 class="animate-rise mb-4 font-serif text-4xl font-semibold tracking-tight text-ink md:text-5xl">
				Cuadros de bordado crewel
			</h1>
			<p class="animate-rise-delay-1 text-lg leading-relaxed text-ink-soft">
				Explora una selección de cuadros únicos bordados a mano con técnica crewel. Si te interesa
				alguna obra, contáctanos para disponibilidad y encargos.
			</p>
		</header>

		<div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
			{cuadros.map((cuadro) => <CuadroCard cuadro={cuadro} />)}
		</div>
	</section>
</Layout>
