---
import Menu from '@lucide/astro/icons/menu';
import X from '@lucide/astro/icons/x';
import { NAV_LINKS, SITE_NAME } from '../consts';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="sticky top-0 z-30 border-b border-border/70 bg-paper/85 backdrop-blur-md">
	<div class="relative mx-auto flex max-w-6xl items-center justify-between px-4 py-3.5 md:px-6">
		<a href="/" class="group font-serif text-xl font-semibold tracking-tight text-forest md:text-2xl">
			<span class="transition-colors duration-200 group-hover:text-moss">{SITE_NAME}</span>
		</a>

		<nav class="hidden items-center gap-8 md:flex" aria-label="Principal">
			{
				NAV_LINKS.map((link) => {
					const isActive =
						pathname === link.href || (link.href !== '/' && pathname.startsWith(link.href));
					return (
						<a
							href={link.href}
							class:list={[
								'relative text-sm font-medium tracking-wide transition-colors duration-200',
								isActive ? 'text-forest' : 'text-muted hover:text-ink',
							]}
							aria-current={isActive ? 'page' : undefined}
						>
							{link.label}
							{isActive && (
								<span
									class="absolute -bottom-1 left-0 h-px w-full bg-thread"
									aria-hidden="true"
								/>
							)}
						</a>
					);
				})
			}
		</nav>

		<button
			id="menu-toggle"
			type="button"
			class="p-2 text-ink-soft transition-colors duration-200 hover:text-forest md:hidden"
			aria-label="Abrir menú"
			aria-expanded="false"
			aria-controls="mobile-menu"
		>
			<Menu id="icon-menu" class="h-6 w-6" aria-hidden="true" />
			<X id="icon-close" class="hidden h-6 w-6" aria-hidden="true" />
		</button>

		<div
			id="mobile-menu"
			class="absolute top-full right-4 z-40 mt-2 hidden w-56 border border-border bg-paper p-2 shadow-lg md:hidden"
			hidden
		>
			{
				NAV_LINKS.map((link) => {
					const isActive =
						pathname === link.href || (link.href !== '/' && pathname.startsWith(link.href));
					return (
						<a
							href={link.href}
							data-mobile-link
							class:list={[
								'block px-3 py-2.5 text-sm font-medium transition-colors duration-200',
								isActive ? 'bg-linen-deep text-forest' : 'text-ink-soft hover:bg-linen hover:text-ink',
							]}
							aria-current={isActive ? 'page' : undefined}
						>
							{link.label}
						</a>
					);
				})
			}
		</div>
	</div>
</header>

<div
	id="menu-backdrop"
	class="fixed inset-0 z-20 hidden bg-ink/25 md:hidden"
	hidden
	role="button"
	tabindex="-1"
	aria-label="Cerrar menú"
></div>

<script>
	function initMobileMenu() {
		const toggle = document.getElementById('menu-toggle');
		const menu = document.getElementById('mobile-menu');
		const backdrop = document.getElementById('menu-backdrop');
		const iconMenu = document.getElementById('icon-menu');
		const iconClose = document.getElementById('icon-close');
		if (!toggle || !menu || !backdrop || !iconMenu || !iconClose) return;

		const setOpen = (open: boolean) => {
			toggle.setAttribute('aria-expanded', String(open));
			toggle.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
			menu.classList.toggle('hidden', !open);
			menu.hidden = !open;
			backdrop.classList.toggle('hidden', !open);
			backdrop.hidden = !open;
			iconMenu.classList.toggle('hidden', open);
			iconClose.classList.toggle('hidden', !open);
		};

		toggle.addEventListener('click', () => {
			setOpen(toggle.getAttribute('aria-expanded') !== 'true');
		});

		backdrop.addEventListener('click', () => setOpen(false));

		menu.querySelectorAll('[data-mobile-link]').forEach((link) => {
			link.addEventListener('click', () => setOpen(false));
		});

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape') setOpen(false);
		});
	}

	initMobileMenu();
	document.addEventListener('astro:page-load', initMobileMenu);
</script>
