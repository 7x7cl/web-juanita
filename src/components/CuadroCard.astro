---
import type { Cuadro } from '../lib/cuadros';

interface Props {
	cuadro: Cuadro;
}

const { cuadro } = Astro.props;
const { titulo, portada, vendido, start, end } = cuadro.data;

function formatDate(date?: { month?: number; year: number }) {
	if (!date) return null;
	return `${date.month ? `${date.month}/` : ''}${date.year}`;
}

const startLabel = formatDate(start);
const endLabel = formatDate(end);
---

<a href={`/cuadros/${cuadro.id}`} class="animate-rise-delay-2 group block">
	<article>
		<div class="aspect-[5/4] overflow-hidden bg-linen-deep">
			<img
				src={portada.src}
				alt={`${titulo} — cuadro bordado crewel`}
				width={portada.width}
				height={portada.height}
				loading="lazy"
				decoding="async"
				class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
			/>
		</div>
		<div class="pt-4">
			<h3 class="font-serif text-xl font-semibold text-ink transition-colors group-hover:text-moss">
				{titulo}
			</h3>
			{startLabel && <p class="mt-1 text-sm text-muted">Empezado: {startLabel}</p>}
			{endLabel && <p class="text-sm text-muted">Terminado: {endLabel}</p>}
			<p class:list={['mt-2 text-sm font-medium', vendido ? 'text-moss' : 'text-muted']}>
				{vendido ? 'Vendido' : 'Disponible'}
			</p>
		</div>
	</article>
</a>
