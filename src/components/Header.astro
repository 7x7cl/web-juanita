---
import Menu from '@lucide/astro/icons/menu';
import X from '@lucide/astro/icons/x';
import { NAV_LINKS, SITE_NAME } from '../consts';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header
	class="sticky top-0 z-30 border-b border-[#d4c4a8] bg-[#faf3e7]/90 backdrop-blur-lg supports-[backdrop-filter]:bg-[#faf3e7]/80"
>
	<div class="relative mx-auto flex max-w-6xl items-center justify-between px-4 py-3">
		<a href="/" class="flex items-center gap-2">
			<span
				class="bg-gradient-to-r from-[#6b4226] to-[#8b5a2b] bg-clip-text text-lg font-bold text-transparent"
			>
				{SITE_NAME}
			</span>
		</a>

		<nav class="hidden gap-2 md:flex" aria-label="Principal">
			{
				NAV_LINKS.map((link) => {
					const isActive = pathname === link.href || (link.href !== '/' && pathname.startsWith(link.href));
					return (
						<a
							href={link.href}
							class:list={[
								'rounded-full px-4 py-2 text-sm font-medium transition-all duration-200',
								isActive
									? 'bg-[#5c4a32] text-[#faf3e7] shadow-sm'
									: 'text-[#5c4a32] hover:bg-[#ece3d0] hover:text-[#3d2e1e]',
							]}
							aria-current={isActive ? 'page' : undefined}
						>
							{link.label}
						</a>
					);
				})
			}
		</nav>

		<button
			id="menu-toggle"
			type="button"
			class="rounded-full p-2 text-[#5c4a32] transition-colors duration-200 hover:bg-[#ece3d0] md:hidden"
			aria-label="Abrir menú"
			aria-expanded="false"
			aria-controls="mobile-menu"
		>
			<Menu id="icon-menu" class="h-6 w-6" aria-hidden="true" />
			<X id="icon-close" class="hidden h-6 w-6" aria-hidden="true" />
		</button>

		<div
			id="mobile-menu"
			class="animate-fade-in absolute top-full right-4 z-40 mt-2 hidden w-56 rounded-2xl border border-[#d4c4a8] bg-[#faf3e7] p-2 shadow-lg md:hidden"
			hidden
		>
			{
				NAV_LINKS.map((link) => {
					const isActive = pathname === link.href || (link.href !== '/' && pathname.startsWith(link.href));
					return (
						<a
							href={link.href}
							data-mobile-link
							class:list={[
								'block rounded-xl px-3 py-2 text-sm font-medium transition-colors duration-200',
								isActive
									? 'bg-[#5c4a32] text-[#faf3e7]'
									: 'text-[#5c4a32] hover:bg-[#ece3d0] hover:text-[#3d2e1e]',
							]}
							aria-current={isActive ? 'page' : undefined}
						>
							{link.label}
						</a>
					);
				})
			}
		</div>
	</div>
</header>

<div
	id="menu-backdrop"
	class="fixed inset-0 z-20 hidden bg-black/20 md:hidden"
	hidden
	role="button"
	tabindex="-1"
	aria-label="Cerrar menú"
></div>

<script>
	function initMobileMenu() {
		const toggle = document.getElementById('menu-toggle');
		const menu = document.getElementById('mobile-menu');
		const backdrop = document.getElementById('menu-backdrop');
		const iconMenu = document.getElementById('icon-menu');
		const iconClose = document.getElementById('icon-close');
		if (!toggle || !menu || !backdrop || !iconMenu || !iconClose) return;

		const setOpen = (open: boolean) => {
			toggle.setAttribute('aria-expanded', String(open));
			toggle.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
			menu.classList.toggle('hidden', !open);
			menu.hidden = !open;
			backdrop.classList.toggle('hidden', !open);
			backdrop.hidden = !open;
			iconMenu.classList.toggle('hidden', open);
			iconClose.classList.toggle('hidden', !open);
		};

		toggle.addEventListener('click', () => {
			setOpen(toggle.getAttribute('aria-expanded') !== 'true');
		});

		backdrop.addEventListener('click', () => setOpen(false));

		menu.querySelectorAll('[data-mobile-link]').forEach((link) => {
			link.addEventListener('click', () => setOpen(false));
		});

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape') setOpen(false);
		});
	}

	initMobileMenu();
	document.addEventListener('astro:page-load', initMobileMenu);
</script>
