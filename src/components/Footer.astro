---
import { SITE_NAME, SOCIAL_LINKS } from '../consts';

const year = new Date().getFullYear();

const social = [
	{ href: SOCIAL_LINKS.email, label: 'Gmail', src: '/logos/gmail.svg' },
	{ href: SOCIAL_LINKS.whatsapp, label: 'WhatsApp', src: '/logos/whatsapp.svg' },
	{ href: SOCIAL_LINKS.instagram, label: 'Instagram', src: '/logos/instagram.svg' },
	{ href: SOCIAL_LINKS.facebook, label: 'Facebook', src: '/logos/facebook.svg' },
] as const;
---

<footer class="border-t border-border bg-forest text-linen">
	<div class="mx-auto flex max-w-6xl flex-col items-center gap-5 px-4 py-10 text-center md:px-6">
		<p class="font-serif text-2xl font-semibold tracking-tight">{SITE_NAME}</p>
		<div class="flex justify-center gap-7">
			{
				social.map(({ href, label, src }) => (
					<a
						href={href}
						target="_blank"
						rel="noopener"
						aria-label={label}
						class="opacity-80 transition-opacity duration-200 hover:opacity-100"
					>
						<img src={src} alt="" class="h-5 w-5 brightness-0 invert" width="20" height="20" />
					</a>
				))
			}
		</div>
		<p class="text-sm text-sage">© {year} · Hecho con cariño en Chile</p>
	</div>
</footer>
